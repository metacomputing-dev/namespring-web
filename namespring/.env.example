# Frontend runtime configuration
VITE_PAYMENT_ENABLED=false
VITE_TOSS_CLIENT_KEY=
# Optional. If unset, frontend calls same-origin /api.
VITE_API_BASE_URL=
# Optional (dev only). If VITE_API_BASE_URL is unset, Vite proxies /api to this target.
# Example: http://localhost:3000
VITE_LOCAL_API_PROXY_TARGET=
# Optional (dev only). Enable only when you specifically need cross-origin isolation for local WASM tooling.
VITE_DEV_ENABLE_CROSS_ORIGIN_ISOLATION=false
# Optional. Override payment app origin.
# If unset in production (non-localhost), defaults to https://namespring-web.vercel.app.
VITE_PAYMENT_APP_ORIGIN=
# Optional. Override canonical redirect origin.
# If unset in production (non-localhost), defaults to https://namespring-web.vercel.app.
VITE_CANONICAL_ORIGIN=

# Toss server-side configuration
TOSS_SECRET_KEY=
TOSS_API_BASE_URL=https://api.tosspayments.com

# Admin refund endpoint protection
ADMIN_REFUND_TOKEN=

# Firebase Admin credentials (choose one approach)
# 1) Single JSON string
FIREBASE_SERVICE_ACCOUNT_JSON=

# 2) Split fields
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
