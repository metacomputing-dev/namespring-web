{
  "framework": "vite",
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/support",
      "destination": "/index.html"
    },
    {
      "source": "/payment/success",
      "destination": "/index.html"
    },
    {
      "source": "/payment/fail",
      "destination": "/index.html"
    }
  ]
}
